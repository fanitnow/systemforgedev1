# ═══════════════════════════════════════════════════════════════════
# SYSTEMFORGE AI — COMPLETE ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Netlify → Site Settings → Environment Variables → Add each key
#   2. They inject into serverless functions automatically
#   3. NEVER paste secret keys into any HTML or JS file
#   4. NEVER commit a real .env to GitHub
# ═══════════════════════════════════════════════════════════════════

# ── 1. ANTHROPIC ──────────────────────────────────────────────────
# Powers: All 5 chat agents + free audit tool
# Get it: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ── 2. SUPABASE URL ───────────────────────────────────────────────
# Powers: All data storage (13 tables)
# Get it: Supabase → Settings → API → Project URL
# Also paste in: public/js/sf-chat-widget.js + public/index.html
SUPABASE_URL=https://REPLACE_ME.supabase.co

# ── 3. SUPABASE ANON KEY ──────────────────────────────────────────
# Powers: Browser-side inserts from chat widget and checkout
# Get it: Supabase → Settings → API → anon public key
# Also paste in: public/js/sf-chat-widget.js + public/index.html
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# ── 4. SUPABASE SERVICE ROLE KEY ─────────────────────────────────
# Powers: Server-side writes from Netlify functions (bypasses RLS)
# Get it: Supabase → Settings → API → service_role key
# ⚠️ NEVER put in any HTML or client JS. Server only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# ── 5. STRIPE PUBLISHABLE KEY ────────────────────────────────────
# Powers: Stripe.js card element in the browser
# Get it: Stripe Dashboard → Developers → API Keys → Publishable key
# ✅ This one IS safe in HTML — Stripe designed it to be public
# Also paste directly in pages/checkout.html replacing:
#   pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# ── 6. STRIPE SECRET KEY ─────────────────────────────────────────
# Powers: Creating PaymentIntents, refunds, customer records
# Get it: Stripe Dashboard → Developers → API Keys → Secret key
# ⚠️ NEVER put in any HTML or client JS
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# ── 7. STRIPE WEBHOOK SECRET ─────────────────────────────────────
# Powers: Verifying webhook payloads are genuinely from Stripe
# Get it: Stripe Dashboard → Webhooks → Add endpoint
#   URL: https://systemsforgeai.com/api/stripe-webhook
#   Events: payment_intent.succeeded, charge.refunded
#   → After saving → Signing secret → Reveal
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── 8. RESEND API KEY ────────────────────────────────────────────
# Powers: Owner alert emails when clients pay or tickets open
# Get it: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_REPLACE_ME

# ── 9. OWNER EMAIL ───────────────────────────────────────────────
# Powers: Destination for all owner alert emails
OWNER_EMAIL=info@systemsforgeai.com

# ── 10. GOHIGHLEVEL ──────────────────────────────────────────────
# Powers: CRM contacts, pipeline stages, email sequences
# Get it: GoHighLevel → Settings → API Keys
# NOTE: These go in Make.com scenarios, not in Netlify
GHL_API_KEY=REPLACE_ME
GHL_LOCATION_ID=REPLACE_ME

# ── 11. MAKE.COM WEBHOOK URLS ────────────────────────────────────
# Powers: Stripe→GHL sync + Audit→cold lead pipeline
# Get it: Make.com → New Scenario → Webhook module → Copy URL
MAKE_STRIPE_WEBHOOK_URL=https://hook.us1.make.com/REPLACE_ME
MAKE_AUDIT_WEBHOOK_URL=https://hook.us1.make.com/REPLACE_ME

# ═══════════════════════════════════════════════════════════════════
# SETUP ORDER
# ═══════════════════════════════════════════════════════════════════
# 1. Supabase  → URL, anon key, service role key
# 2. Stripe    → publishable key, secret key (use test keys first)
# 3. Anthropic → API key
# 4. Resend    → API key, verify domain
# 5. Netlify   → add all keys to Environment Variables
# 6. Deploy    → test with Stripe test card: 4242 4242 4242 4242
# 7. GHL       → API key, location ID (for Make.com)
# 8. Make.com  → build 2 scenarios, get webhook URLs
# 9. Go live   → switch to Stripe live keys
# 10. Webhook  → add Stripe endpoint, get webhook secret
# ═══════════════════════════════════════════════════════════════════
